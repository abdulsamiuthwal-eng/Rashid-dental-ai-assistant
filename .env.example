# =============================================================================
# Rashid Dental AI Assistant — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Replace ALL placeholder values with your actual credentials.
#   3. NEVER commit the .env file to version control.
#   4. Rotate credentials if they are accidentally exposed.
# =============================================================================


# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Environment: development | staging | production
APP_ENV=development

# Application name (used in logging, metadata)
APP_NAME=Rashid Dental AI Assistant

# Application version
APP_VERSION=1.0.0

# Server host (use 0.0.0.0 for Docker, 127.0.0.1 for local)
APP_HOST=127.0.0.1

# Server port
APP_PORT=8000

# Enable debug mode (True only in development — NEVER in production)
DEBUG=True

# CORS allowed origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500


# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Secret key for JWT / session signing — generate a strong random value
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# JWT algorithm (HS256 recommended for symmetric, RS256 for asymmetric)
JWT_ALGORITHM=HS256

# JWT token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30


# -----------------------------------------------------------------------------
# Google Gemini API
# -----------------------------------------------------------------------------

# Google Gemini API Key — obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model to use (e.g., gemini-1.5-pro, gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# Maximum tokens in Gemini response
GEMINI_MAX_OUTPUT_TOKENS=1024

# Temperature for response generation (0.0 = deterministic, 1.0 = creative)
# Recommended for medical/dental context: 0.2 — 0.4
GEMINI_TEMPERATURE=0.3


# -----------------------------------------------------------------------------
# Database — PostgreSQL
# -----------------------------------------------------------------------------

# Full PostgreSQL connection URL
# Format: postgresql+asyncpg://username:password@host:port/database_name
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/rashid_dental

# Individual connection parameters (alternative to DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rashid_dental
DB_USER=postgres
DB_PASSWORD=

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10


# -----------------------------------------------------------------------------
# Vector Store — FAISS
# -----------------------------------------------------------------------------

# Directory to persist FAISS index files
FAISS_INDEX_PATH=./backend/vector_store/faiss_index

# Embedding model to use (Google or HuggingFace)
EMBEDDING_MODEL=models/embedding-001


# -----------------------------------------------------------------------------
# Knowledge Base
# -----------------------------------------------------------------------------

# Path to Markdown knowledge base directory
KNOWLEDGE_BASE_PATH=./knowledge-base

# Chunk size for document splitting (characters)
CHUNK_SIZE=1000

# Chunk overlap for context continuity
CHUNK_OVERLAP=200


# -----------------------------------------------------------------------------
# RAG Pipeline Settings
# -----------------------------------------------------------------------------

# Number of top documents to retrieve for context
RAG_TOP_K=5

# Minimum similarity score threshold (0.0 - 1.0)
RAG_SIMILARITY_THRESHOLD=0.7

# Maximum context length passed to LLM (characters)
RAG_MAX_CONTEXT_LENGTH=4000


# -----------------------------------------------------------------------------
# Conversation Memory
# -----------------------------------------------------------------------------

# Maximum number of conversation turns to retain in memory
CONVERSATION_MEMORY_WINDOW=10

# Conversation session TTL in seconds (default: 1 hour)
CONVERSATION_SESSION_TTL=3600


# -----------------------------------------------------------------------------
# Appointment System
# -----------------------------------------------------------------------------

# Notification email for new appointment requests
APPOINTMENT_NOTIFICATION_EMAIL=

# SMTP server settings (for email notifications — Phase 6+)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=True


# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Maximum chat requests per user per minute
RATE_LIMIT_CHAT_PER_MINUTE=20

# Maximum appointment requests per user per hour
RATE_LIMIT_APPOINTMENTS_PER_HOUR=5


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log output directory
LOG_DIR=./logs

# Log file name
LOG_FILE=app.log


# -----------------------------------------------------------------------------
# Frontend (if using separate frontend server)
# -----------------------------------------------------------------------------

# Backend API base URL (used by frontend)
VITE_API_BASE_URL=http://localhost:8000

# Public app name shown in browser title
VITE_APP_NAME=Rashid Dental AI Assistant
